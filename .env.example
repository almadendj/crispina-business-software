# Copy to `.env.local` and fill in. `.env.local` is gitignored — never commit secrets.
# Values come from the Supabase project (CRI-2). The app must still run for local
# UI work without these set; cloud sync simply stays offline until they exist.

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key (safe to expose to the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
